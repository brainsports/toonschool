# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Gemini API Configuration
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# 공개 체험(데모) 기능 — 프런트엔드 토글. true 로 켜야 홈페이지 체험 버튼 동작.
# (운영 도메인에서만 true 권장. docs/demo-accounts-setup.md 참고)
VITE_DEMO_LOGIN_ENABLED=false

# 만화 생성 횟수 제한 기능
# 운영 DB에 comic quota 마이그레이션이 적용된 경우에만 true 사용
VITE_COMIC_QUOTA_ENABLED=false

# 아래 값들은 프런트엔드 번들에 절대 들어가지 않는다(Git/보고/로그 금지).
# Supabase Edge Function Secret 으로만 등록(docs/demo-accounts-setup.md 3단계):
#   DEMO_STUDENT_EMAIL / DEMO_STUDENT_PASSWORD
#   DEMO_TEACHER_EMAIL / DEMO_TEACHER_PASSWORD
# 프로비저닝 스크립트(scripts/provision-demo-accounts.ts)용 로컬 .env(커밋 금지):
#   SUPABASE_URL / SUPABASE_SERVICE_ROLE_KEY

